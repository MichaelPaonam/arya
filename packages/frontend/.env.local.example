# App Mode: "hackathon" (demo-scoped) or "full" (all pages visible)
NEXT_PUBLIC_APP_MODE=hackathon

# WalletConnect — get a free project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Managed LLM key (server-side) — used when users don't provide their own
OPENROUTER_API_KEY=

# Upstash Redis — pipeline state + sessions (https://upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Uniswap Trading API — swap quotes + routing (https://developers.uniswap.org)
UNISWAP_API_KEY=

# KeeperHub — automated monitoring workflows (https://keeperhub.com)
KEEPERHUB_API_KEY=

# 0G Storage — agent memory persistence
ZERO_G_PRIVATE_KEY=

# Smart Account Session Key — signs 0G uploads via smart account (replaces ZERO_G_PRIVATE_KEY)
SESSION_KEY_PRIVATE_KEY=
SMART_ACCOUNT_ADDRESS=

# Session Key config (public)
NEXT_PUBLIC_SESSION_KEY_ADDRESS=
NEXT_PUBLIC_ZG_FLOW_ADDRESS=
